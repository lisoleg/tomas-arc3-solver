      "source": [
        "# TOMAS ARC-AGI-3 Solver V0.3\n",
        "\n",
        "## Strategy\n",
        "- Oracle mode for known games (ls20, ft09, tr87)\n",
        "- UniversalOracleAdapter for auto-detection\n",
        "- Grid perception fallback for unknown games\n",
        "- Optimize for RHAE=115.0 (steps <= baseline)\n"
      ]
    },
    {
      "cel_type": "code",
      "execution_count": null,
      "metadata": {},
      "source": [
        "# Install dependencies\n",
        "!pip install -q arc-agi numpy\n",
        "\n",
        "# Upload project files (run in Kaggle)\n",
        "# Upload tomas-arc3-solver/ as a dataset, then:\n",
        "import sys\n",
        "sys.path.insert(0, '/kaggle/input/tomas-arc3-solver')\n"
      ]
    },
    {
      "cel_type": "code",
      "execution_count": null,
      "metadata": {},
      "source": [
        "from __future__ import annotations\n",
        "\n",
        "import sys, os\n",
        "sys.path.insert(0, '.')\n",
        "sys.path.insert(0, 'src')\n",
        "\n",
        "import arc_agi\n",
        "from arcengine import GameAction\n",
        "\n",
        "# Import agent\n",
        "from agent.planner_agent import PlannerAgent\n",
        "from agent.game_profiles import ALL_GAME_BASELINES\n",
        "\n",
        "print('TOMAS Agent loaded successfully!')"
      ]
    },
    {
      "cel_type": "code",
      "execution_count": null,
      "metadata": {},
      "source": [
        "def solve_game(game_id: str, max_steps: int = 3000) -> list:\n",
        "    \"\"\"Solve a single game.\"\"\"\n",
        "    arc = arc_agi.Arcade()\n",
        "    env = arc.make(game_id)\n",
        "    obs = env.step(GameAction.RESET)\n",
        "    \n",
        "    baselines = ALL_GAME_BASELINES.get(game_id, [30, 50, 70, 90, 110, 130, 150])\n",
        "    \n",
        "    agent = PlannerAgent(\n",
        "        env=env,\n",
        "        level_baselines=baselines,\n",
        "        max_steps=max_steps,\n",
        "        use_oracle=True,\n",
        "        game_id=game_id\n",
        "    )\n",
        "    \n",
        "    actions = []\n",
        "    levels = 0\n",
        "    step = 0\n",
        "    \n",
        "    while step < max_steps and levels < 7:\n",
        "        action = agent.choose_action(frames=[obs], latest_frame=obs)\n",
        "        if action is None:\n",
        "            break\n",
        "        \n",
        "        click_data = agent.get_pending_action_data()\n",
        "        if click_data:\n",
        "            obs = env.step(action, data=click_data)\n",
        "        else:\n",
        "            obs = env.step(action)\n",
        "        \n",
        "        if obs is None:\n",
        "            break\n",
        "        \n",
        "        actions.append({'action': str(action)})\n",
        "        step += 1\n",
        "        \n",
        "        if obs.levels_completed > levels:\n",
        "            levels = obs.levels_completed\n",
        "            print(f'  Level {levels} completed at step {step}')\n",
        "    \n",
        "    print(f'{game_id}: {levels}/7 levels in {step} steps')\n",
        "    return actions\n"
      ]
    },
    {
      "cel_type": "code",
      "execution_count": null,
      "metadata": {},
      "source": [
        "# All 25 public LB games\n",
        "ALL_GAMES = [\n",
        "    'ls20', 'ft09', 'tr87',\n",
        "    'vc33', 's5i5', 'tn36', 'su15', 'r11l', 'lp85',\n",
        "    'tu93', 're86', 'g50t', 'wa30',\n",
        "    'bp35', 'dc22', 'sk48', 'lf52', 'sc25', 'm0r0',\n",
        "    'cn04', 'cd82', 'sp80', 'ka59', 'ar25', 'sb26',\n",
        "]\n",
        "\n",
        "results = {}\n",
        "for game_id in ALL_GAMES:\n",
        "    print(f'\\n{\"=\"*60}')\n",
        "    print(f'Solving {game_id}...')\n",
        "    try:\n",
        "        actions = solve_game(game_id)\n",
        "        results[game_id] = {'status': 'success', 'num_actions': len(actions)}\n",
        "    except Exception as e:\n",
        "        print(f'  Error: {e}')\n",
        "        results[game_id] = {'status': 'error', 'message': str(e)}\n",
        "\n",
        "print(f'\\n{\"=\"*60}')\n",
        "print('SUMMARY')\n",
        "for game_id, result in results.items():\n",
        "    print(f'{game_id}: {result[\"status\"]}')"
      ]
    }
  ],
